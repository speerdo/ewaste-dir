{
  "name": "directory-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development astro dev",
    "prebuild": "npm run cleanup",
    "build": "NODE_ENV=production astro build",
    "build:vercel": "npm run cleanup && NODE_OPTIONS=\"--max-old-space-size=7168 --expose-gc\" NODE_ENV=production astro build --verbose",
    "build:optimized": "node scripts/optimize-for-build.js && npm run cleanup && NODE_OPTIONS=\"--max-old-space-size=7168 --expose-gc\" NODE_ENV=production astro build",
    "prebuild:old": "npm run cleanup",
    "verify": "npm run verify-ssr",
    "verify-ssr": "node scripts/verify-ssr.js",
    "preview": "vercel dev",
    "astro": "astro",
    "import-data": "node scripts/import-data.js",
    "collect-local-data": "node scripts/collect-local-data.js",
    "test-scraper": "node scripts/test-scraper.js",
    "scrape-websites": "node scripts/web-scraper.js",
    "retry-failed": "node scripts/retry-failed-websites.js",
    "research-places": "node scripts/google-places-researcher.js",
    "update-database": "node scripts/update-database.js",
    "scrape-and-update": "npm run scrape-websites && npm run update-database",
    "sync-cities": "node scripts/sync-cities-table.js",
    "generate-descriptions": "node scripts/generate-city-descriptions.js",
    "verify-descriptions": "node scripts/verify-city-descriptions.js",
    "verify-factual-accuracy": "node scripts/verify-factual-accuracy.js",
    "fetch-news": "node scripts/fetch-local-news.js",
    "check-fact-check": "bash scripts/check-fact-check-progress.sh",
    "apply-corrections": "node scripts/apply-corrections.js",
    "review-corrections": "node scripts/review-corrections.js",
    "analyze-description-quality": "node scripts/analyze-description-quality.js",
    "fix-database-descriptions": "node scripts/fix-database-descriptions.js",
    "import-descriptions": "node scripts/import-city-descriptions.js",
    "analyze-descriptions": "node scripts/analyze-description-accuracy.js",
    "regenerate-descriptions": "node scripts/regenerate-descriptions.js",
    "bulk-fix-specialties": "node scripts/bulk-fix-incorrect-specialties.js",
    "check-progress": "node scripts/check-progress.js",
    "verify-centers": "node scripts/verify-recycling-centers.js",
    "descriptions-workflow": "npm run sync-cities && npm run generate-descriptions && npm run verify-descriptions",
    "clean": "rm -rf dist node_modules/.astro node_modules/.vite .vercel/output",
    "cleanup": "rm -rf dist/ .vercel/output/ .temp-build/"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.4",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.101.1",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.1.3",
    "autoprefixer": "^10.4.27",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.4.0",
    "fast-xml-parser": "^5.3.2",
    "node-fetch": "^3.3.2",
    "openai": "^6.33.0",
    "postcss": "^8.5.8",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": "^20.19.1 || >=22.12.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "@vercel/node": "^5.6.9"
  }
}

---
interface Props {
  cityName: string;
  state: string;
}

const { cityName, state } = Astro.props;
---

<!-- Local News Section - Fetched client-side (CDN-cached via /api/news) -->
<div 
  id="local-news-container" 
  class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-lg p-6 mb-6"
  data-city={cityName}
  data-state={state}
>
  <div class="flex items-center mb-4">
    <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
      <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
      </svg>
    </div>
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Recent Recycling News in {cityName}</h2>
      <p class="text-sm text-gray-600 mt-1">
        Latest news and updates about electronics recycling in {cityName}, {state}
      </p>
    </div>
  </div>
  
  <!-- Loading State -->
  <div id="news-loading" class="text-center py-8">
    <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
    <p class="text-gray-600 mt-2 text-sm">Loading news...</p>
  </div>
  
  <!-- Error State (hidden by default) -->
  <div id="news-error" class="hidden text-center py-8">
    <p class="text-gray-600 text-sm">Unable to load news at this time.</p>
  </div>
  
  <!-- News Articles Container (populated by JavaScript) -->
  <div id="news-articles" class="space-y-4 hidden"></div>
</div>

<script>
  (async function() {
    const container = document.getElementById('local-news-container');
    const loadingEl = document.getElementById('news-loading');
    const errorEl = document.getElementById('news-error');
    const articlesEl = document.getElementById('news-articles');
    
    if (!container || !loadingEl || !errorEl || !articlesEl) return;
    
    const cityName = container.dataset.city;
    const state = container.dataset.state;
    
    if (!cityName || !state) {
      loadingEl.classList.add('hidden');
      errorEl.classList.remove('hidden');
      errorEl.innerHTML = '<p class="text-gray-600 text-sm">Unable to load news: missing location data.</p>';
      return;
    }
    
    try {
      const apiUrl = `/api/news?city=${encodeURIComponent(cityName)}&state=${encodeURIComponent(state)}`;
      const response = await fetch(apiUrl);
      
      if (!response.ok) {
        throw new Error(`Failed to fetch news: ${response.status}`);
      }
      
      const data = await response.json();
      const articles = data.articles || [];
      
      const sixMonthsAgo = new Date();
      sixMonthsAgo.setMonth(sixMonthsAgo.getMonth() - 6);
      
      const recentArticles = articles
        .filter((article: { pubDate?: string }) => {
          if (!article.pubDate) return false;
          return new Date(article.pubDate) >= sixMonthsAgo;
        })
        .sort((a: { pubDate: string }, b: { pubDate: string }) =>
          new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
        )
        .slice(0, 3);
      
      if (recentArticles.length === 0) {
        loadingEl.classList.add('hidden');
        errorEl.classList.remove('hidden');
        errorEl.innerHTML = '<p class="text-gray-600 text-sm">No recent recycling news found for this area. Check back later for updates!</p>';
        return;
      }
      
      loadingEl.classList.add('hidden');
      articlesEl.classList.remove('hidden');
      
      articlesEl.innerHTML = recentArticles.map((article: {
        link: string;
        image?: string;
        title?: string;
        description?: string;
        source?: string;
        pubDate?: string;
      }) => {
        const hasImage = article.image && article.image.length > 0;
        const safeTitle = (article.title || 'Untitled').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        const safeSource = (article.source || 'News').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        
        return `
        <a 
          href="${article.link}"
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-white rounded-lg overflow-hidden border border-blue-200 hover:border-blue-400 hover:shadow-lg transition-all group"
        >
          <div class="flex items-start gap-4">
            ${hasImage ? `
              <div class="flex-shrink-0 w-32 h-32 rounded-lg overflow-hidden bg-gray-100">
                <img 
                  src="${article.image}" 
                  alt="${safeTitle.replace(/"/g, '&quot;')}"
                  class="w-full h-full object-cover"
                  loading="lazy"
                  onerror="this.style.display='none'; this.parentElement.classList.add('hidden');"
                />
              </div>
            ` : ''}
            <div class="flex-1 p-4 flex items-start justify-between min-w-0">
              <div class="flex-1">
                <h3 class="font-semibold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">
                  ${safeTitle}
                </h3>
                ${article.description ? `
                  <p class="text-sm text-gray-600 line-clamp-2 mb-3">
                    ${article.description.replace(/</g, '&lt;').replace(/>/g, '&gt;')}
                  </p>
                ` : ''}
                <div class="flex items-center gap-3 text-xs text-gray-500">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
                    </svg>
                    ${safeSource}
                  </span>
                  ${article.pubDate ? `
                    <span class="flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                      ${new Date(article.pubDate).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric'
                      })}
                    </span>
                  ` : ''}
                </div>
              </div>
              <svg class="w-5 h-5 text-blue-600 ml-3 flex-shrink-0 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </div>
          </div>
        </a>
      `;
      }).join('');
      
    } catch {
      loadingEl.classList.add('hidden');
      errorEl.classList.remove('hidden');
      errorEl.innerHTML = '<p class="text-gray-600 text-sm">Unable to load news at this time.</p>';
    }
  })();
</script>

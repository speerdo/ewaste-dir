---
import type { RecyclingCenter } from '../../types/supabase';
import { formatWorkingHours } from '../../utils/formatWorkingHours';

interface Props {
  center: RecyclingCenter;
  defaultLogo: string;
  verifiedPartner?: {
    tier: 'premium' | 'featured';
    description?: string;
    logo_url?: string;
  } | null;
}

const { center, defaultLogo, verifiedPartner = null } = Astro.props;


// Extract business specialties from description and name
function getBusinessSpecialties(center: RecyclingCenter): string[] {
  const text = (center.description || center.name || '').toLowerCase();
  const specialties: string[] = [];
  const excluded = (center.excluded_specialties || []).map(s => s.toLowerCase());
  
  const serviceTypes = {
    'Electronics Recycling': ['electronic', 'computer', 'phone', 'laptop', 'tablet', 'tv', 'monitor', 'printer'],
    'Metal Recycling': ['metal recycling', 'scrap metal', 'metal scrap', 'scrap recycling'], // More specific - require actual metal recycling mention
    'Automotive Recycling': ['auto', 'car', 'vehicle', 'tire', 'battery', 'automotive'],
    'Computer Repair': ['repair', 'fix', 'diagnostic', 'refurbish'], // Removed 'service' - too broad
    'Data Destruction': ['data', 'destruction', 'shredding', 'secure', 'certified'],
    'Appliance Recycling': ['appliance', 'refrigerator', 'washer', 'dryer', 'dishwasher']
  };
  
  Object.entries(serviceTypes).forEach(([specialty, keywords]) => {
    // Skip if this specialty is in the excluded list
    if (excluded.includes(specialty.toLowerCase())) {
      return;
    }
    // For Metal Recycling, require exact phrase match (more strict)
    if (specialty === 'Metal Recycling') {
      if (keywords.some(keyword => text.includes(keyword))) {
        specialties.push(specialty);
      }
    } else {
      // For others, use word boundary matching where appropriate
      if (keywords.some(keyword => text.includes(keyword))) {
        specialties.push(specialty);
      }
    }
  });
  
  return specialties.slice(0, 3); // Limit to 3 specialties
}

const businessSpecialties = getBusinessSpecialties(center);

// Safely parse JSONB arrays that may arrive as arrays, JSON strings, or null
function parseJsonArray(val: any): string[] {
  if (!val) return [];
  if (Array.isArray(val)) return val.filter(v => typeof v === 'string' && v.trim());
  if (typeof val === 'string') {
    try {
      const parsed = JSON.parse(val);
      return Array.isArray(parsed) ? parsed.filter(Boolean) : [];
    } catch { return []; }
  }
  return [];
}

const acceptedItems   = parseJsonArray(center.accepted_items);
const shownItems      = acceptedItems.slice(0, 5);
const extraItemCount  = acceptedItems.length - shownItems.length;
const servicesOffered = parseJsonArray(center.services_offered);
const certifications  = parseJsonArray(center.certifications);

const listingDescription = center.description?.trim() ?? '';
const descriptionUsesClamp =
  listingDescription.length > 0 &&
  (listingDescription.length > 140 || listingDescription.includes('\n'));
---

<div 
  id={`center-${center.id}`}
  class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-all duration-300 cursor-pointer" 
  data-center-id={center.id}
  data-rating={center.rating ? Number(center.rating).toFixed(1) : "0"}
  data-name={center.name}
  data-lat={center.latitude}
  data-lng={center.longitude}
  data-legitimacy-score={center.legitimacy_score || "0"}
  data-is-legitimate={center.is_legitimate ? "true" : "false"}
  onclick={`
    // Remove highlight from all centers
    document.querySelectorAll('[data-center-id]').forEach(el => el.classList.remove('highlight-center'));
    // Add highlight to this center
    this.classList.add('highlight-center');
    // Dispatch event for map marker
    window.dispatchEvent(new CustomEvent('markerClick', { detail: { centerId: '${center.id}' }}));
  `}
>
  <div class="p-4">
    <div class="flex items-start justify-between">
      <div class="flex-grow">
        <div class="flex items-start justify-between mb-2">
          <h3 class="text-xl font-semibold text-gray-900 mr-4">
            {center.name}
          </h3>
        </div>
        {/* Verified partner badge */}
        {verifiedPartner && (
          <div class="mb-2">
            <span
              class:list={[
                'inline-flex items-center gap-1 rounded-full font-medium border px-2.5 py-1 text-xs',
                verifiedPartner.tier === 'featured'
                  ? 'bg-amber-50 text-amber-800 border-amber-300'
                  : 'bg-green-50 text-green-800 border-green-300',
              ]}
              title="This business has been verified by RecycleOldTech.com"
            >
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              {verifiedPartner.tier === 'featured' ? 'Featured Partner' : 'Verified Partner'}
            </span>
          </div>
        )}
        
        <!-- Business Specialties -->
        {/* Temporarily disabled - will re-enable after verifying all centers (28,000+ API calls needed) */}
        {/* {businessSpecialties.length > 0 && (
          <div class="mb-3">
            <div class="flex flex-wrap gap-1">
              {businessSpecialties.map(specialty => (
                <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-gray-100 text-gray-800">
                  {specialty}
                </span>
              ))}
            </div>
          </div>
        )} */}
        
        {center.rating && (
          <div class="flex items-center mb-2">
            {Array.from({ length: Math.round(Number(center.rating)) }).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            <span class="ml-2 text-gray-600">
              {Number(center.rating).toFixed(1)} ({center.reviews || 0} reviews)
            </span>
          </div>
        )}

        {/* Accepted items — shown on all cards */}
        {shownItems.length > 0 && (
          <div class="flex flex-wrap gap-1 mb-1">
            {shownItems.map(item => (
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700">
                {item.charAt(0).toUpperCase() + item.slice(1)}
              </span>
            ))}
            {extraItemCount > 0 && (
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-500">
                +{extraItemCount} more
              </span>
            )}
          </div>
        )}

      </div>
      
      <div class="flex-shrink-0 ml-4">
        {(center.logo || center.photo) ? (
          <img 
            src={center.logo || center.photo}
            alt={`${center.name} ${center.logo ? 'company logo' : 'facility photo'}`}
            loading="lazy"
            class={`w-16 h-16 rounded-lg bg-gray-50 ${center.logo ? 'object-contain' : 'object-cover'}`}
            onerror={`
              this.onerror=null; 
              this.src='${defaultLogo}'; 
              this.alt='Electronics recycling center logo';
              this.setAttribute('data-fallback', 'true');
            `}
            role="img"
            aria-describedby={`logo-desc-${center.id}`}
          />
        ) : (
          <div 
            class="w-16 h-16 rounded-lg bg-gray-100 flex items-center justify-center" 
            role="img" 
            aria-label={`${center.name} - Default electronics recycling center icon`}
            aria-describedby={`logo-desc-${center.id}`}
          >
            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
        )}
        <span id={`logo-desc-${center.id}`} class="sr-only">
          {center.logo ? `Company logo for ${center.name}` : `Facility photo for ${center.name}`}, an electronics recycling center
        </span>
      </div>
    </div>

    <div class="mt-3 space-y-2">
      <div class="flex items-start">
        <svg class="w-4 h-4 text-gray-400 mr-2 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <address class="not-italic text-sm text-gray-600">
          {center.full_address}
        </address>
      </div>

      {center.phone && (
        <div class="flex items-center">
          <svg class="w-4 h-4 text-gray-400 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <a href={`tel:${center.phone}`} class="text-sm text-green-600 hover:text-green-700">
            {center.phone}
          </a>
        </div>
      )}

      {center.site && (
        <div class="flex items-center">
          <svg class="w-4 h-4 text-gray-400 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m-9 9a9 9 0 019-9" />
          </svg>
          <a href={center.site} target="_blank" rel="noopener noreferrer" class="text-sm text-green-600 hover:text-green-700">
            Visit Website
          </a>
        </div>
      )}

      {listingDescription && (
        <div class="min-w-0">
          <p
            id={`desc-${center.id}`}
            class:list={[
              'text-gray-500 text-sm whitespace-pre-line',
              descriptionUsesClamp && 'line-clamp-3',
            ]}
          >{listingDescription}</p>
          {descriptionUsesClamp && (
            <button
              type="button"
              class="mt-1 text-xs font-medium text-green-600 hover:text-green-700"
              onclick={`event.stopPropagation(); const p=document.getElementById('desc-${center.id}'); p.classList.toggle('line-clamp-3'); this.textContent=p.classList.contains('line-clamp-3')?'Show more':'Show less'`}
            >
              Show more
            </button>
          )}
        </div>
      )}

      {/* Services & certifications — verified partners only */}
      {verifiedPartner && servicesOffered.length > 0 && (
        <div class="flex items-start gap-3">
          <svg class="w-6 h-6 text-gray-400 mr-0 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
          <div class="flex flex-wrap gap-1">
            {servicesOffered.map(svc => (
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700">
                {svc}
              </span>
            ))}
          </div>
        </div>
      )}

      {verifiedPartner && certifications.length > 0 && (
        <div class="flex items-start gap-3">
          <svg class="w-6 h-6 text-gray-400 mr-0 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
          <div class="flex flex-wrap gap-1">
            {certifications.map(cert => (
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-50 text-amber-700">
                {cert}
              </span>
            ))}
          </div>
        </div>
      )}

      {center.working_hours && (
        <div class="flex items-start">
          <svg class="w-4 h-4 text-gray-400 mr-2 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div class="text-gray-600">
            <button 
              type="button"
              class="hours-toggle flex items-center gap-2 hover:text-green-600 transition-colors"
              onclick="this.setAttribute('aria-expanded', this.getAttribute('aria-expanded') === 'true' ? 'false' : 'true'); document.getElementById(this.getAttribute('aria-controls')).style.display = this.getAttribute('aria-expanded') === 'true' ? 'block' : 'none'; this.querySelector('svg').classList.toggle('rotate-180')"
              aria-expanded="false"
              aria-controls={`hours-${center.id}`}
              data-hours-toggle
            >
              <span>Opening Hours</span>
              <svg class="w-4 h-4 transform transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div 
              id={`hours-${center.id}`}
              class="mt-2 space-y-1"
              style="display: none;"
            >
              {formatWorkingHours(center.working_hours).split('\n').map(line => {
                const colonIdx = line.indexOf(': ');
                if (colonIdx < 0) {
                  return (
                    <div class="py-1">
                      <span class="text-gray-600">{line}</span>
                    </div>
                  );
                }
                const day = line.slice(0, colonIdx);
                const time = line.slice(colonIdx + 2);
                return (
                  <div class="flex justify-between py-1">
                    <span class="font-medium text-gray-700">{day}</span>
                    <span class="text-gray-600">{time}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      )}
    </div>


    <div class="mt-6 flex flex-wrap gap-4">
      {center.phone && (
        <a
          href={`tel:${center.phone}`}
          class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
        >
          Call Now
        </a>
      )}
      {center.site && (
        <a
          href={center.site}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
        >
          Visit Website
        </a>
      )}
      <button
        onclick={`window.showDirections(${center.latitude}, ${center.longitude})`}
        class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
      >
        Get Directions
      </button>
    </div>

    {/* Claim listing button for unverified centers */}
    {!verifiedPartner && (
      <div class="mt-4 pt-3 -mx-4 -mb-4 px-4 py-3 bg-green-50/60 border-t border-green-100 flex items-center justify-between">
        <span class="text-xs text-gray-400">Is this your business?</span>
        <a
          href={`/claim?business=${encodeURIComponent(center.name)}&city=${encodeURIComponent(center.city || '')}&state=${encodeURIComponent(center.state || '')}`}
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-green-700 border border-green-500 rounded-md hover:bg-green-600 hover:text-white transition-colors"
          onclick="event.stopPropagation()"
        >
          Claim this listing
        </a>
      </div>
    )}
  </div>
</div> 

---
export const prerender = true;
import { Image } from 'astro:assets';
import { smartphoneInHandImg, phonesImg, autumnLaptopImg, retroGamingImg, storeRecyclingImg, dataSecurityImg, phoneRepairImg, cashLaptopImg } from '../assets/images';
import Layout from '../layouts/Layout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

const AFFILIATE_LINK = "https://amzn.to/3Kk2E45";

const faqItems = [
  {
    question: 'How much is my laptop worth for trade-in?',
    answer: "It depends on the brand, model, age, and condition. Working MacBooks from the last 4-5 years typically trade in for the most, often $150-$500+. Mainstream Windows laptops (Dell, HP, Lenovo) usually trade in for $20-$200 depending on specs and condition. Get an instant, no-obligation quote to see your exact laptop's value.",
  },
  {
    question: 'Can I trade in a laptop that has a cracked screen or won’t turn on?',
    answer: "Yes. Amazon Trade-In accepts laptops in 'Acceptable' condition, which includes cracked screens, dead batteries, and units that won't power on. You'll receive a lower offer than for a fully working laptop, but it still has value rather than being scrapped.",
  },
  {
    question: 'Do I need to wipe my laptop before trading it in?',
    answer: 'Yes, always back up your files and perform a factory reset before trading in or recycling any laptop. This protects your personal information and is required by most trade-in and recycling programs.',
  },
  {
    question: 'What if my device is damaged?',
    answer: "Amazon still accepts damaged devices, but the trade-in value will be lower. It's worth getting a quote to see what your device is worth – you might be surprised!",
  },
  {
    question: 'How do I get paid for my trade-in?',
    answer: 'Amazon Trade-In provides an Amazon.com gift card, not cash. This is applied directly to your Amazon account. If you prefer cash, consider other trade-in services or selling your device privately.',
  },
  {
    question: 'How long does the laptop trade-in process take?',
    answer: "After you ship your device (free with the prepaid label), Amazon typically verifies and processes your trade-in within 5-10 business days. You'll receive your gift card once verification is complete.",
  },
];
---

<Layout
  title="Laptop Trade In for Cash | Trade In Your Old Electronics | RecycleOldTech"
  description="Trade in your laptop, phone, tablet, or gaming console for an instant Amazon gift card quote. See what old laptops are worth, free shipping, and no obligation."
>
  <SchemaMarkup type="faq" data={{ questions: faqItems }} />

  <!-- Hero Section -->
  <div class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-b from-green-900/90 via-green-800/85 to-green-700/90"></div>
      <div class="absolute inset-0 opacity-10">
        <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
          <defs>
            <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
              <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/>
            </pattern>
          </defs>
          <rect width="100" height="100" fill="url(#grid)" />
        </svg>
      </div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="flex items-center justify-center mb-6">
        <div class="w-20 h-20 bg-green-200/20 rounded-full flex items-center justify-center mr-6">
          <svg class="w-10 h-10 text-green-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white text-center">Laptop Trade In for Cash (Plus Phones, Tablets & More)</h1>
      </div>
      <p class="text-xl text-green-50 text-center max-w-3xl mx-auto mb-8">
        Before you recycle your old laptop, phone, or tablet, you might be able to get cash for it! Here's what your laptop trade-in is really worth and how electronic trade-in programs work.
      </p>
      <div class="flex justify-center">
        <a 
          href={AFFILIATE_LINK}
          target="_blank"
          rel="noopener noreferrer sponsored"
          class="inline-flex items-center bg-white text-green-700 px-8 py-4 rounded-lg font-bold text-lg shadow-lg hover:shadow-xl hover:bg-green-50 transition-all transform hover:-translate-y-1"
        >
          Check Your Device Value
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        
        <!-- How Amazon Trade-In Works -->
        <section class="mb-16">
          <div class="flex items-center mb-8">
            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h2 class="text-3xl font-display font-bold text-gray-900">How Amazon Trade-In Works</h2>
          </div>
          
          <div class="grid md:grid-cols-3 gap-8 mb-10">
            <div class="text-center">
              <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-emerald-600">1</span>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Get an Instant Quote</h3>
              <p class="text-gray-600">Answer a few questions about your device's condition and get an estimated trade-in value immediately.</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-emerald-600">2</span>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Ship It for Free</h3>
              <p class="text-gray-600">Amazon provides a prepaid shipping label. Pack your device and drop it off at any UPS location.</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-emerald-600">3</span>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Receive Your Gift Card</h3>
              <p class="text-gray-600">Once your device is verified, you'll receive an Amazon gift card within days.</p>
            </div>
          </div>

          <div class="flex justify-center">
            <a 
              href={AFFILIATE_LINK}
              target="_blank"
              rel="noopener noreferrer sponsored"
              class="inline-flex items-center bg-emerald-600 text-white px-8 py-4 rounded-lg font-bold text-lg shadow-md hover:bg-emerald-700 hover:shadow-lg transition-all"
            >
              Check Your Device Value
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </section>

        <!-- Visual break with phone image -->
        <div class="relative mb-16 rounded-xl overflow-hidden">
          <Image src={smartphoneInHandImg} alt="Trading in a smartphone" width={1200} height={256} class="w-full h-64 object-cover" />
          <div class="absolute inset-0 bg-gradient-to-r from-emerald-900/80 to-teal-900/60 flex items-center">
            <div class="px-8">
              <h3 class="text-2xl font-bold text-white mb-2">Your Old Device Has Value</h3>
              <p class="text-emerald-100">Even older phones, tablets, and laptops can earn you Amazon credit.</p>
            </div>
          </div>
        </div>

        <!-- What Devices Can You Trade In -->
        <section class="mb-16">
          <div class="flex items-center mb-8">
            <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <h2 class="text-3xl font-display font-bold text-gray-900">What Devices Can You Trade In?</h2>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
            <!-- Phones & Tablets -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow overflow-hidden">
              <div class="h-40 overflow-hidden">
                <Image src={phonesImg} alt="Smartphones for trade-in" width={400} height={160} class="w-full h-full object-cover" />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-gray-900 mb-3">Phones & Tablets</h3>
                <ul class="text-gray-600 space-y-2 mb-6">
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    iPhones (iPhone 8 and newer)
                  </li>
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    Samsung Galaxy devices
                  </li>
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    iPads and Android tablets
                  </li>
                </ul>
                <a 
                  href={AFFILIATE_LINK}
                  target="_blank"
                  rel="noopener noreferrer sponsored"
                  class="inline-flex items-center text-blue-600 font-medium hover:text-blue-800 transition-colors"
                >
                  See Phone Trade-In Values
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>

            <!-- Laptops & Computers -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow overflow-hidden">
              <div class="h-40 overflow-hidden">
                <Image src={autumnLaptopImg} alt="Laptop for trade-in" width={400} height={160} class="w-full h-full object-cover" />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-gray-900 mb-3">Laptops & Computers</h3>
                <ul class="text-gray-600 space-y-2 mb-6">
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    MacBooks
                  </li>
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    Windows laptops
                  </li>
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    Gaming laptops
                  </li>
                </ul>
                <a 
                  href={AFFILIATE_LINK}
                  target="_blank"
                  rel="noopener noreferrer sponsored"
                  class="inline-flex items-center text-purple-600 font-medium hover:text-purple-800 transition-colors"
                >
                  Check Laptop Trade-In Value
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>

            <!-- Gaming Consoles -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow overflow-hidden">
              <div class="h-40 overflow-hidden">
                <Image src={retroGamingImg} alt="Gaming consoles for trade-in" width={400} height={160} class="w-full h-full object-cover" />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-gray-900 mb-3">Gaming Consoles</h3>
                <ul class="text-gray-600 space-y-2 mb-6">
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    PlayStation 4/5
                  </li>
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    Xbox One/Series X
                  </li>
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    Nintendo Switch
                  </li>
                </ul>
                <a 
                  href={AFFILIATE_LINK}
                  target="_blank"
                  rel="noopener noreferrer sponsored"
                  class="inline-flex items-center text-red-600 font-medium hover:text-red-800 transition-colors"
                >
                  Trade In Gaming Console
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </section>

        <!-- Laptop Trade-In Guide -->
        <section class="mb-16">
          <div class="flex items-center mb-8">
            <div class="w-12 h-12 bg-emerald-100 rounded-lg flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
              </svg>
            </div>
            <h2 class="text-3xl font-display font-bold text-gray-900">Laptop Trade In: What's Your Laptop Worth?</h2>
          </div>

          <div class="md:flex gap-10 items-center mb-10">
            <div class="md:w-1/2 mb-8 md:mb-0 rounded-xl overflow-hidden">
              <Image src={cashLaptopImg} alt="Cash value for a used laptop trade-in" width={600} height={400} class="w-full h-full object-cover" />
            </div>
            <div class="md:w-1/2">
              <p class="text-gray-700 leading-relaxed mb-4">
                Laptop trade-in value depends mainly on three things: brand, age, and condition. Before you recycle an old laptop, it's worth checking its trade-in value first &mdash; even laptops with cracked screens or dead batteries are often worth something.
              </p>
              <ul class="text-gray-700 space-y-2">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <span><strong>MacBooks</strong> hold value longest &mdash; even 5-6 year old models can be worth $150-$400+.</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <span><strong>Windows laptops</strong> (Dell, HP, Lenovo) trade in for less but still add up, especially business-grade and gaming models.</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <span><strong>Broken or won't power on?</strong> Amazon's "Acceptable" condition tier still accepts laptops with cracked screens or dead batteries at a reduced value.</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <span><strong>Storage and specs matter</strong> &mdash; higher RAM/SSD configurations and larger screens generally trade in for more.</span>
                </li>
              </ul>
              <a
                href={AFFILIATE_LINK}
                target="_blank"
                rel="noopener noreferrer sponsored"
                class="inline-flex items-center mt-6 bg-emerald-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-emerald-700 transition-all"
              >
                Get Your Laptop's Trade-In Value
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-6">
            <h3 class="font-semibold text-gray-900 mb-3">Before you trade in your laptop:</h3>
            <ol class="text-gray-700 space-y-2 list-decimal list-inside">
              <li>Back up your files to an external drive or cloud storage.</li>
              <li>Sign out of all accounts (iCloud, Google, Microsoft) and disable Find My Mac / Find My Device.</li>
              <li>Perform a full factory reset to wipe personal data.</li>
              <li>Remove any SD cards, dongles, or accessories not included with the original device.</li>
            </ol>
          </div>
        </section>

        <!-- Visual break with recycling image -->
        <div class="relative mb-16 rounded-xl overflow-hidden">
          <Image src={storeRecyclingImg} alt="Electronics recycling drop-off" width={1200} height={256} class="w-full h-64 object-cover" />
          <div class="absolute inset-0 bg-gradient-to-l from-gray-900/80 to-gray-900/40 flex items-center justify-end">
            <div class="px-8 text-right max-w-md">
              <h3 class="text-2xl font-bold text-white mb-2">No Trade-In Value?</h3>
              <p class="text-gray-200">If your device is too old or damaged for trade-in, responsible recycling is the next best option.</p>
            </div>
          </div>
        </div>

        <!-- When to Trade-In vs. Recycle -->
        <section class="mb-16">
          <div class="flex items-center mb-8">
            <div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="text-3xl font-display font-bold text-gray-900">When to Trade-In vs. Recycle</h2>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-emerald-50 p-8 rounded-xl border-l-4 border-emerald-500">
              <h3 class="text-xl font-bold text-emerald-800 mb-4">Trade-In is Best When:</h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Device is less than 5 years old</span>
                </li>
                <li class="flex items-start gap-3">
